# Federated Learning system defaults.
# Copy to .env on each machine and edit local paths/roles.
# Do not put Tailscale auth keys or other secrets in this file.

# Common FL runtime
FL_RUN_ID=local-run
FL_OUTPUT_DIR=outputs/local-run
FL_NUM_CLIENTS=2
FL_NUM_ROUNDS=1
FL_SEED=2026

# Optional dropout/straggler robustness overrides.
# Leave unset for strict baseline runs: train/evaluate/availability require all
# FL_NUM_CLIENTS. For a 1-of-2 Colab robustness smoke, set all three to 1.
# FL_MIN_TRAIN_NODES=1
# FL_MIN_EVALUATE_NODES=1
# FL_MIN_AVAILABLE_NODES=1

# Current workload data paths.
# PPE detection is the current test workload; future workloads can reuse the same
# system keys when they expose manifest/data-root style inputs.
FL_MANIFEST_PATH=configs/datasets/ppe_detection_exp011_manifest.csv
FL_DATA_ROOT=data/ppe

# Per-machine role. Leave blank on the server/local simulation. On SuperNodes,
# set one of the site labels available in that client's manifest.
FL_CLIENT_ID=

# Runtime resources and common training knobs
FL_DEVICE=auto
FL_NUM_WORKERS=0
FL_BATCH_SIZE=2
FL_LOCAL_EPOCHS=1

# Detection-workload knobs used by the current PPE trial
FL_IMAGE_SIZE=512
FL_PRETRAINED=true
FL_LR=0.005
FL_MOMENTUM=0.9
FL_WEIGHT_DECAY=0.0005
FL_SCORE_THRESHOLD=0.05

# Legacy aliases such as FL_DET_* are still accepted for compatibility, but new
# machine configs should prefer the FL_* names above.
